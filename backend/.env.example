# ─────────────────────────────────────────────────────────────────────────
# MooMetrics backend configuration. Copy to backend/.env for local dev.
# In production the app refuses to boot with insecure defaults (see config.py).
# ─────────────────────────────────────────────────────────────────────────

# Environment: development | staging | production
ENVIRONMENT=development

# --- Auth -----------------------------------------------------------------
# Generate a strong secret for production: `openssl rand -hex 32`
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
# Brute-force lockout
MAX_FAILED_LOGINS=5
LOCKOUT_MINUTES=15

# --- Database -------------------------------------------------------------
# SQLite for local dev; PostgreSQL required in production.
DATABASE_URL=sqlite:///./moometrics.db
# DATABASE_URL=postgresql://moometrics:password@localhost:5432/moometrics

# --- CORS -----------------------------------------------------------------
FRONTEND_URL=http://localhost:3000

# --- Initial admin (seeded on first startup only) -------------------------
ADMIN_USERNAME=admin
# Required in production (the default 'admin123' is rejected).
ADMIN_INITIAL_PASSWORD=admin123
DEFAULT_FARM_NAME=Default Farm

# --- Image storage --------------------------------------------------------
# local: disk under UPLOAD_DIR (served at /uploads). s3: AWS S3 / Cloudflare R2.
STORAGE_BACKEND=local
UPLOAD_DIR=uploads/deaths
# S3 / R2 (only when STORAGE_BACKEND=s3)
S3_BUCKET=
S3_ENDPOINT_URL=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# --- Observability --------------------------------------------------------
LOG_LEVEL=INFO
# console for local readability; json in production for log aggregation.
LOG_FORMAT=console
# Optional Sentry error tracking (no-op when empty).
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
